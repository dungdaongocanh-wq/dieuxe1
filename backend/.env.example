# Cấu hình môi trường backend
# Copy file này thành .env và điền giá trị thực

# JWT Secret - THAY ĐỔI trong production!
JWT_SECRET=dna_express_secret_key_change_in_production

# Port server (Railway tự set $PORT, không cần đổi)
PORT=3001

# Môi trường
NODE_ENV=production

# Đường dẫn SQLite DB (Railway volume)
# Khi deploy Railway, set DB_PATH=/data/dieuxe.db và mount volume tại /data
DB_PATH=./data/dieuxe.db

# URL frontend (dùng cho CORS khi deploy production)
# VD: https://dieuxe-frontend.up.railway.app
FRONTEND_URL=http://localhost:5173
