# Cấu hình môi trường backend - Dùng MySQL (XAMPP)
# XAMPP mặc định: user=root, password=(để trống), port=3306
# Tạo database tên "dna_express_db" trong phpMyAdmin trước khi chạy

DATABASE_URL="mysql://root:@localhost:3306/dna_express_db"

# Nếu XAMPP có đặt mật khẩu MySQL, dùng dòng dưới (thay "matkhau" bằng mật khẩu thật):
# DATABASE_URL="mysql://root:matkhau@localhost:3306/dna_express_db"

JWT_SECRET="dna_express_secret_key_change_in_production"
PORT=3001
NODE_ENV=development
